# Telegram Remote gateway (v0) — copy to .env and fill in. See README.md.

# Required: Telegram bot token from @BotFather.
SKC_TELEGRAM_REMOTE_BOT_TOKEN=123456:telegram-bot-token

# Default-deny allowlist. Provide at least one of user ids or chat ids (comma-separated).
SKC_TELEGRAM_REMOTE_ALLOWED_USER_IDS=11111111
# SKC_TELEGRAM_REMOTE_ALLOWED_CHAT_IDS=-1001234567890

# Approved presets (JSON array). Only a preset id may be named from chat.
SKC_TELEGRAM_REMOTE_PRESETS=[{"id":"proj","workdir":"/home/bot/src/project","sessionCommand":"skc --worktree","taskTemplate":"Use /skill:ralplan to plan: {{task}}","taskMaxLen":2000}]

# Enable /stop (adds the `reports` mutation class). Omit/false to stay read+start only.
SKC_TELEGRAM_REMOTE_ENABLE_STOP=false

# Rich messaging (HTML + inline keyboards). Default on; set false for plain text.
# Optional push notifications use the Coordinator MCP watch_events surface when ENABLE_PUSH=true.
# SKC_TELEGRAM_REMOTE_ENABLE_RICH=true
# SKC_TELEGRAM_REMOTE_RICH_CALLBACK_TTL_MS=600000
# SKC_TELEGRAM_REMOTE_RICH_CALLBACK_MAX_TOKENS=500
# SKC_TELEGRAM_REMOTE_ENABLE_EDIT_MESSAGE_TEXT=false
# SKC_TELEGRAM_REMOTE_REGISTER_COMMANDS=true
# SKC_TELEGRAM_REMOTE_ENABLE_PUSH=false
# SKC_TELEGRAM_REMOTE_FOLLOW_TTL_MS=86400000
# SKC_TELEGRAM_REMOTE_SUBSCRIPTIONS_MAX=1000
# SKC_TELEGRAM_REMOTE_WATCH_TIMEOUT_MS=25000
# SKC_TELEGRAM_REMOTE_DIGEST_THRESHOLD=5

# Optional tuning.
# SKC_TELEGRAM_REMOTE_DEFAULT_TASK_MAX_LEN=2000
# SKC_TELEGRAM_REMOTE_POLL_TIMEOUT_SEC=30
# SKC_TELEGRAM_REMOTE_API_BASE=https://api.telegram.org

# Optional coordinator overrides (defaults: skc mcp-serve coordinator).
# SKC_TELEGRAM_REMOTE_COORDINATOR_COMMAND=skc
# SKC_TELEGRAM_REMOTE_COORDINATOR_ARGS=mcp-serve,coordinator
# Optional RPC backend mode. Set BACKEND=rpc to use a persistent skc RPC-mode
# session over an owner-only UNIX socket. In RPC mode this gateway dials an
# existing socket only; it never spawns/kills the session. The socket's OS
# ownership is the real boundary (same-UID trusted v1), and the latest UDS
# client wins controller ownership.
# SKC_TELEGRAM_REMOTE_BACKEND=coordinator
# SKC_TELEGRAM_REMOTE_RPC_SOCKET=/path/to/skc-rpc.sock
# SKC_TELEGRAM_REMOTE_STATE_DIR=/path/to/state
# SKC_TELEGRAM_REMOTE_LIVENESS_MS=60000
# SKC_TELEGRAM_REMOTE_ALLOW_ATTACH_SOCKET_ARG=false


# Optional coordinator namespace/state passthrough.
# SKC_COORDINATOR_MCP_WORKDIR_ROOTS=/home/bot/src/project
# SKC_COORDINATOR_MCP_SESSION_COMMAND=skc --worktree
# SKC_COORDINATOR_MCP_PROFILE=telegram-remote
# SKC_COORDINATOR_MCP_REPO=project
# SKC_COORDINATOR_MCP_STATE_ROOT=
# SKC_COORDINATOR_MCP_ARTIFACT_BYTE_CAP=

# Managed service examples:
#   Linux: examples/systemd/ (systemd user units + service env example)
#   macOS: examples/launchd/ (LaunchAgent parity + shell-compatible env example)
# Real copied env files must be owned by the service user and mode 0600.
