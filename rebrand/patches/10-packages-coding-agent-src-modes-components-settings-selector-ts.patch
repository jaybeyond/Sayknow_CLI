+// Settings UI strings are translated by deterministic keys derived from the
+// setting path; English (the schema value) is the fallback. Keys match those
+// generated into i18n/messages/<lang>.settings.ts.
+function tSettingLabel(def: SettingDef): string {
+	return def.label ? td(`set:${def.path}:l`, def.label) : def.label;
+}
+function tSettingDesc(def: SettingDef): string {
+	return def.description ? td(`set:${def.path}:d`, def.description) : def.description;
+}
+function tSettingOptions<T extends { value: string; label?: string; description?: string }>(
+	path: string,
+	options: ReadonlyArray<T>,
+): T[] {
+	return options.map(o => ({
+		...o,
+		label: o.label ? td(`set:${path}:o:${o.value}:l`, o.label) : o.label,
+		description: o.description ? td(`set:${path}:o:${o.value}:d`, o.description) : o.description,
+	}));
+}
