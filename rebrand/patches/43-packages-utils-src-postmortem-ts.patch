+/**
+ * True for terminal/pipe/disk write failures (EIO, EPIPE, EBADF, …) on the write side.
+ * Covers external-volume stalls and terminal hangups that surface as a late uncaught
+ * exception mid-shutdown — a benign artifact upstream's stdout-EPIPE classifier misses.
+ * Only write-side syscalls match so genuine read/logic bugs are never masked.
+ */
+function isBenignIoWriteError(err: unknown): boolean {
+	if (!err || typeof err !== "object") return false;
+	const { code, syscall } = err as { code?: unknown; syscall?: unknown };
+	const isIoCode =
+		code === "EIO" ||
+		code === "EPIPE" ||
+		code === "EBADF" ||
+		code === "ENXIO" ||
+		code === "ENOTTY" ||
+		code === "ECONNRESET";
+	return isIoCode && (syscall === undefined || syscall === "write" || syscall === "writev");
 }
 
