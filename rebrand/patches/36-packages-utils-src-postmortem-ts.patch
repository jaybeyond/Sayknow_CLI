+/**
+ * True for terminal/pipe write failures (EIO, EPIPE, EBADF, …) on the write side.
+ *
+ * Bun flushes TTY writes asynchronously, so when the controlling terminal hangs up
+ * (terminal closed, external volume stalled, SSH dropped) a restore write issued during
+ * shutdown can surface as an uncaughtException on a later tick — after cleanup has already
+ * begun. Treating that as fatal logs a scary stack and exits nonzero, which a hosting
+ * terminal renders as a crash/restart loop. When it happens mid-shutdown it is a benign
+ * artifact, not a real fault. We only match write-side syscalls so genuine bugs (a read
+ * EIO, a logic error that happens to carry one of these codes) are never masked.
+ */
+function isBenignIoWriteError(err: unknown): boolean {
+	if (!err || typeof err !== "object") return false;
+	const { code, syscall } = err as { code?: unknown; syscall?: unknown };
+	const isIoCode =
+		code === "EIO" ||
+		code === "EPIPE" ||
+		code === "EBADF" ||
+		code === "ENXIO" ||
+		code === "ENOTTY" ||
+		code === "ECONNRESET";
+	return isIoCode && (syscall === undefined || syscall === "write" || syscall === "writev");
+}
