{
	"type": "module",
	"name": "@sayknow-cli/bridge-client",
	"version": "0.4.4",
	"description": "Transport-only v3 SDK WebSocket client",
	"homepage": "https://sayknow-cli.com",
	"author": "jaybeyond and Sayknow-CLI Contributors",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jaybeyond/Sayknow_CLI.git",
		"directory": "packages/bridge-client"
	},
	"bugs": {
		"url": "https://github.com/jaybeyond/Sayknow_CLI/issues"
	},
	"keywords": [
		"sdk",
		"websocket",
		"transport",
		"client"
	],
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsc -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"test": "bun test",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write ."
	},
	"devDependencies": {
		"@types/bun": "catalog:"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"files": [
		"src"
	],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		}
	}
}
