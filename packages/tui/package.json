{
	"type": "module",
	"name": "@sayknow-cli/tui",
	"version": "0.3.2",
	"description": "Terminal User Interface library with differential rendering for efficient text-based applications",
	"homepage": "https://github.com/jaybeyond/Sayknow_CLI",
	"author": "jaybeyond",
	"contributors": [
		"Mario Zechner"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jaybeyond/Sayknow_CLI.git",
		"directory": "packages/tui"
	},
	"bugs": {
		"url": "https://github.com/jaybeyond/Sayknow_CLI/issues"
	},
	"keywords": [
		"tui",
		"terminal",
		"ui",
		"text-editor",
		"differential-rendering",
		"typescript",
		"cli"
	],
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"test": "bun test test/*.test.ts",
		"test:perf": "PI_TUI_PERF_GATES=1 bun test test/perf-gates.test.ts",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write ."
	},
	"dependencies": {
		"@sayknow-cli/natives": "catalog:",
		"@sayknow-cli/utils": "catalog:",
		"lru-cache": "catalog:",
		"marked": "catalog:"
	},
	"devDependencies": {
		"chalk": "catalog:",
		"@xterm/headless": "catalog:"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"files": [
		"src",
		"README.md",
		"CHANGELOG.md"
	],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./*": {
			"types": "./src/*.ts",
			"import": "./src/*.ts"
		},
		"./components/*": {
			"types": "./src/components/*.ts",
			"import": "./src/components/*.ts"
		},
		"./*.js": "./src/*.ts"
	}
}
