{
	"type": "module",
	"private": true,
	"name": "@sayknow-cli/typescript-edit-benchmark",
	"version": "0.3.0",
	"description": "Edit benchmark suite using TypeScript source code mutations",
	"author": "jaybeyond",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jaybeyond/Sayknow_CLI.git",
		"directory": "packages/typescript-edit-benchmark"
	},
	"main": "./src/index.ts",
	"bin": {
		"typescript-edit-benchmark": "src/index.ts"
	},
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"test": "bun test",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write .",
		"generate": "bun run src/generate.ts --typescript-dir /tmp/pi-mono-source --count-per-type 4",
		"start": "bun run src/index.ts"
	},
	"dependencies": {
		"@babel/generator": "catalog:",
		"@babel/parser": "catalog:",
		"@babel/traverse": "catalog:",
		"@babel/types": "catalog:",
		"@sayknow-cli/agent-core": "catalog:",
		"@sayknow-cli/coding-agent": "catalog:",
		"@sayknow-cli/utils": "catalog:",
		"diff": "catalog:",
		"prettier": "catalog:",
		"regexp-tree": "catalog:",
		"@sayknow-cli/ai": "catalog:",
		"@sayknow-cli/tui": "catalog:"
	},
	"devDependencies": {
		"@types/babel__generator": "catalog:",
		"@types/babel__traverse": "catalog:",
		"@types/bun": "catalog:"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"homepage": "https://github.com/jaybeyond/Sayknow_CLI"
}
