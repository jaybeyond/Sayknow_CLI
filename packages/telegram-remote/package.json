{
	"type": "module",
	"private": true,
	"name": "@sayknow-cli/telegram-remote",
	"version": "0.4.0",
	"description": "v0 Telegram operator remote for Sayknow-CLI sessions: a tiny, safe command + bounded-read gateway over the Coordinator MCP. Lifecycle and observation only; not a remote cockpit.",
	"author": "jaybeyond",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jaybeyond/Sayknow_CLI.git",
		"directory": "packages/telegram-remote"
	},
	"main": "./src/index.ts",
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"test": "bun test",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write .",
		"start": "bun run src/cli.ts"
	},
	"devDependencies": {
		"@types/bun": "catalog:"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"homepage": "https://github.com/jaybeyond/Sayknow_CLI",
	"dependencies": {
		"@sayknow-cli/coding-agent": "catalog:"
	}
}
