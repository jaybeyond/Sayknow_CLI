# Telegram Remote service environment file.
# Copy to ~/.config/skc/telegram-remote.env, fill in real values, then:
#   chmod 600 ~/.config/skc/telegram-remote.env
#   chmod 700 ~/.config/skc
# Do NOT commit the copied file. The bot token remains visible to this Unix user
# as process environment; see README for LoadCredential/systemd-creds hardening notes.

SKC_TELEGRAM_REMOTE_BOT_TOKEN=123456:telegram-bot-token
SKC_TELEGRAM_REMOTE_ALLOWED_USER_IDS=11111111
# SKC_TELEGRAM_REMOTE_ALLOWED_CHAT_IDS=-1001234567890

# Default coordinator backend. Set to rpc for the two-unit RPC deployment.
SKC_TELEGRAM_REMOTE_BACKEND=coordinator

# Coordinator mode presets and optional stop support.
SKC_TELEGRAM_REMOTE_PRESETS=[{"id":"proj","workdir":"/home/you/src/project","sessionCommand":"skc --worktree","taskTemplate":"Use /skill:ralplan to plan: {{task}}","taskMaxLen":2000}]
SKC_TELEGRAM_REMOTE_ENABLE_STOP=false

# RPC mode: these app env values must be concrete paths. systemd %h/%t
# specifiers are not expanded by telegram-remote.
# SKC_TELEGRAM_REMOTE_BACKEND=rpc
# SKC_TELEGRAM_REMOTE_RPC_SOCKET=/run/user/1000/skc/telegram-remote.sock
# SKC_TELEGRAM_REMOTE_STATE_DIR=/home/you/.local/state/skc/telegram-remote
# SKC_TELEGRAM_REMOTE_LIVENESS_MS=60000
# SKC_TELEGRAM_REMOTE_ALLOW_ATTACH_SOCKET_ARG=false

# Optional runtime tuning.
# SKC_TELEGRAM_REMOTE_ENABLE_RICH=true
# SKC_TELEGRAM_REMOTE_ENABLE_EDIT_MESSAGE_TEXT=false
# SKC_TELEGRAM_REMOTE_REGISTER_COMMANDS=true
# SKC_TELEGRAM_REMOTE_POLL_TIMEOUT_SEC=30
# SKC_TELEGRAM_REMOTE_API_BASE=https://api.telegram.org

# Optional coordinator overrides.
# SKC_TELEGRAM_REMOTE_COORDINATOR_COMMAND=skc
# SKC_TELEGRAM_REMOTE_COORDINATOR_ARGS=mcp-serve,coordinator
# SKC_COORDINATOR_MCP_WORKDIR_ROOTS=/home/you/src/project
# SKC_COORDINATOR_MCP_SESSION_COMMAND=skc --worktree
